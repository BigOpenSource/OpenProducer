# Social comments graphic — platform credentials
# Copy this file to .env and fill in the values you need.
# Twitch and Kick do not require credentials (anonymous read access).

# YouTube Data API v3 key — https://console.cloud.google.com/apis/credentials
# Used to resolve liveChatId from a videoId and poll live chat messages.
YOUTUBE_API_KEY=

# X (Twitter) API v2 Bearer Token — https://developer.x.com/en/portal/dashboard
# Basic tier or above required. Used to poll replies by conversation_id.
X_BEARER_TOKEN=
